{
  "expo": {
    "name": "Khoảnh Khắc Đáng Nhớ",
    "slug": "zim-memorable-moments",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zim.memorablemoments"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.zim.memorablemoments"
    },
    "scheme": "zim-moments",
    "newArchEnabled": true
  }
}
